{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Config",
  "type": "object",
  "required": [
    "host",
    "port"
  ],
  "properties": {
    "host": {
      "description": "IP or hostname",
      "type": "string"
    },
    "port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    }
  }
}
